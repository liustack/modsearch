{
  "name": "@liustack/modsearch",
  "version": "0.1.0",
  "description": "Provider-extensible CLI search bridge for LLM agent workflows",
  "type": "module",
  "bin": {
    "modsearch": "./dist/main.js"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm build",
    "docs:list": "node scripts/docs-list.js"
  },
  "files": [
    "dist",
    "skills/modsearch/SKILL.md",
    "skills/modsearch/references"
  ],
  "keywords": [
    "search",
    "cli",
    "llm",
    "agent",
    "provider",
    "gemini",
    "modsearch"
  ],
  "author": "Leon Liu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liustack/modsearch.git"
  },
  "bugs": {
    "url": "https://github.com/liustack/modsearch/issues"
  },
  "homepage": "https://github.com/liustack/modsearch#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@tavily/core": "^0.6.0",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.7",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vitest": "^3.2.4"
  }
}
